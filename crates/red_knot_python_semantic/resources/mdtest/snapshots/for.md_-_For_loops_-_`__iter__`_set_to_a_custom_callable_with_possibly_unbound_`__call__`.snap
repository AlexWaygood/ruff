# Python source files

## mdtest_snippet.py

```
 1 | from typing_extensions import ClassVar, reveal_type
 2 | 
 3 | def _(flag: bool):
 4 |     class Iterator:
 5 |         def __next__(self) -> int:
 6 |             return 42
 7 | 
 8 |     class MaybeCallable:
 9 |         if flag:
10 |             def __call__(self, *args, **kwargs) -> Iterator:
11 |                 return 42
12 | 
13 |     class Foo:
14 |         __iter__: ClassVar[MaybeCallable] = MaybeCallable()
15 | 
16 |     # error: [not-iterable]
17 |     for x in Foo():
18 |         reveal_type(x)  # revealed: int
19 | 
20 |     class Bar:
21 |         __iter__ = MaybeCallable()
22 | 
23 |     # error: [not-iterable]
24 |     for y in Bar():
25 |         reveal_type(y)  # revealed: Unknown | int
```

